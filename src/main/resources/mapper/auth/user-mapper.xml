<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >

<mapper namespace="com.beyond.beatbuddy.auth.mapper.UserMapper">

    <resultMap id="UserResultMap" type="User">
        <id property="userId" column="user_id"/>
        <result property="email" column="email"/>
        <result property="password" column="password"/>
        <result property="kakaoId" column="kakao_id"/>
        <result property="provider" column="provider"/>
        <result property="nickname" column="nickname"/>
        <result property="gender" column="gender"/>
        <result property="birthYear" column="birth_year"/>
        <result property="profileImageUrl" column="profile_image_url"/>
        <result property="isTutorialViewed" column="is_tutorial_viewed"/>
        <result property="isTasteAnalyzed" column="is_taste_analyzed"/>
        <result property="status" column="status"/>
        <result property="allowPushChat" column="allow_push_chat"/>
        <result property="allowPushSocial" column="allow_push_social"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="existsByEmail" resultType="boolean">
        SELECT COUNT(*) > 0
        FROM users
        WHERE email = #{email}
    </select>

    <insert id="save" useGeneratedKeys="true" keyProperty="userId">
        INSERT INTO users (
            email, password, nickname, gender, birth_year,
            profile_image_url, provider, status
        ) VALUES (
                     #{email}, #{password}, #{nickname}, #{gender}, #{birthYear},
                     #{profileImageUrl}, #{provider}, #{status}
                 )
    </insert>

    <select id="findByEmail" resultMap="UserResultMap">
        SELECT * FROM users
        WHERE email = #{email}
          AND status = 'ACTIVE'
    </select>

    <select id="findByUserId" resultMap="UserResultMap">
        SELECT * FROM users
        WHERE user_id = #{userId}
          AND status = 'ACTIVE'
    </select>

    <update id="updatePassword">
        UPDATE users
        SET password = #{password}
        WHERE user_id = #{userId}
    </update>

    <update id="updateStatusDeleted">
        UPDATE users
        SET status = 'DELETED'
        WHERE user_id = #{userId}
    </update>

    <select id="findIsTasteAnalyzedByUserId" resultType="boolean">
        SELECT is_taste_analyzed
        FROM users
        WHERE user_id = #{userId}
    </select>

    <select id="findByEmailIncludeDeleted" resultType="User">
        SELECT * FROM users WHERE email = #{email}
    </select>

</mapper>
